{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",

    "strict": true,
    "esModuleInterop": true,

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "outDir": "dist"
  },
  "include": ["./**/*.ts"]
}